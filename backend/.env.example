# ─────────────────────────────────────────────────────────────────────────────
# FastAPI Backend Environment Variables
# Copy to backend/.env and fill in your values.
# NEVER commit backend/.env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Database ───────────────────────────────────────────────────────────────────
# Async URL (used by SQLAlchemy in the app)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:54322/postgres
# Sync URL (used by Alembic migrations)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:54322/postgres

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key      # NEVER expose to frontend
SUPABASE_JWT_SECRET=your-jwt-secret                  # Found in Supabase Dashboard > Settings > API

# ── AI ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=                                      # Optional fallback

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list handled by pydantic-settings
# CORS_ORIGINS=["http://localhost:3000"]

# ── Storage ────────────────────────────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET=resources
MAX_UPLOAD_SIZE_MB=50

# ── Sentry ─────────────────────────────────────────────────────────────────────
SENTRY_DSN=
