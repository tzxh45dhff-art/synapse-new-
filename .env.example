# ─────────────────────────────────────────────────────────────────────────────
# Next.js (frontend) environment
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local. Anything NEXT_PUBLIC_* ships to the browser — no secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Frontend) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Backend URL ────────────────────────────────────────────────────────────────
# BACKEND_URL             → server-side (Server Actions + api-client)
# NEXT_PUBLIC_BACKEND_URL → browser (AI Notes SSE streaming, notes-stream.ts)
# NEXT_PUBLIC_API_URL     → browser (squad members / settings / invite pages)
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Bunker

# ── Rate limiting (optional — Upstash Redis REST; no-op if unset) ───────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
